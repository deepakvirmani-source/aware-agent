# Aware Agent — Environment Variables
# Copy this file to .env and fill in your keys.
# All keys are OPTIONAL — the app works without them using free fallbacks.

# Claude AI (Anthropic) — for intelligent impact analysis
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenWeatherMap — for weather and AQI data
# Free tier: 1,000 calls/day. Sign up at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# AQICN (Air Quality Index) — for AQI data (optional, 'demo' token works for most cities)
# Free token at: https://aqicn.org/data-platform/token/
AQICN_TOKEN=demo
